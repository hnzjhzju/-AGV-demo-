<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>智慧港口 AGV 调度系统 · 数字孪生仿真</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Noto+Sans+SC:wght@300;400;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg:       #050d14;
    --panel:    #080f18;
    --border:   #0e2233;
    --amber:    #f5a623;
    --amber2:   #ffcc44;
    --cyan:     #00d4ff;
    --cyan2:    #00fff7;
    --green:    #39ff14;
    --red:      #ff3a3a;
    --purple:   #9b59ff;
    --text:     #c8dde8;
    --dim:      #3a5568;
    --mono:     'Share Tech Mono', monospace;
    --display:  'Orbitron', monospace;
    --body-cn:  'Noto Sans SC', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--body-cn);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── Header ── */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 24px;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(90deg, #050d14 0%, #071522 50%, #050d14 100%);
    flex-shrink: 0;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .logo-icon {
    width: 36px; height: 36px;
    border: 2px solid var(--amber);
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    animation: pulse-border 3s ease-in-out infinite;
  }
  @keyframes pulse-border {
    0%,100% { border-color: var(--amber); box-shadow: 0 0 0 0 rgba(245,166,35,0); }
    50%      { border-color: var(--amber2); box-shadow: 0 0 8px 2px rgba(245,166,35,.3); }
  }
  .logo-text {
    font-family: var(--display);
    font-size: 13px;
    font-weight: 700;
    color: var(--amber);
    letter-spacing: 2px;
    line-height: 1.3;
  }
  .logo-sub {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--dim);
    letter-spacing: 1px;
  }
  .header-stats {
    display: flex; gap: 28px;
  }
  .hstat {
    text-align: right;
  }
  .hstat-val {
    font-family: var(--display);
    font-size: 20px;
    font-weight: 700;
    line-height: 1;
  }
  .hstat-label {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--dim);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .hstat.amber .hstat-val { color: var(--amber); }
  .hstat.cyan  .hstat-val { color: var(--cyan);  }
  .hstat.green .hstat-val { color: var(--green); }
  .hstat.red   .hstat-val { color: var(--red);   }

  .header-right {
    display: flex; align-items: center; gap: 16px;
  }
  #clock {
    font-family: var(--display);
    font-size: 22px;
    color: var(--cyan2);
    letter-spacing: 3px;
  }
  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: blink 1.4s ease-in-out infinite;
  }
  @keyframes blink {
    0%,100% { opacity: 1; }
    50%      { opacity: .3; }
  }

  /* ── Main layout ── */
  .main {
    flex: 1;
    display: grid;
    grid-template-columns: 200px 1fr 210px;
    gap: 0;
    overflow: hidden;
  }

  /* ── Side panels ── */
  .side-panel {
    background: var(--panel);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .side-panel.right {
    border-right: none;
    border-left: 1px solid var(--border);
  }
  .panel-title {
    font-family: var(--display);
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--amber);
    padding: 10px 12px 6px;
    border-bottom: 1px solid var(--border);
    text-transform: uppercase;
  }

  /* AGV list */
  .agv-list {
    flex: 1;
    overflow-y: auto;
    padding: 6px 0;
  }
  .agv-list::-webkit-scrollbar { width: 3px; }
  .agv-list::-webkit-scrollbar-thumb { background: var(--border); }

  .agv-item {
    padding: 7px 12px;
    border-bottom: 1px solid rgba(14,34,51,.6);
    cursor: pointer;
    transition: background .15s;
  }
  .agv-item:hover { background: rgba(0,212,255,.05); }
  .agv-item.selected { background: rgba(0,212,255,.08); border-left: 2px solid var(--cyan); }

  .agv-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 4px;
  }
  .agv-id {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: bold;
  }
  .agv-state-badge {
    font-family: var(--mono);
    font-size: 8px;
    padding: 1px 5px;
    border-radius: 2px;
    text-transform: uppercase;
  }
  .state-IDLE       { background: rgba(58,85,104,.4); color: var(--dim); }
  .state-MOVING     { background: rgba(0,212,255,.15); color: var(--cyan); }
  .state-DELIVERING { background: rgba(155,89,255,.15); color: var(--purple); }
  .state-LOADING    { background: rgba(245,166,35,.15); color: var(--amber); }
  .state-UNLOADING  { background: rgba(245,166,35,.15); color: var(--amber); }
  .state-CHARGING   { background: rgba(57,255,20,.1); color: var(--green); }
  .state-BLOCKED    { background: rgba(255,58,58,.15); color: var(--red); }

  .battery-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .battery-fill {
    height: 100%;
    border-radius: 2px;
    transition: width .3s;
  }

  /* ── Canvas area ── */
  .canvas-area {
    position: relative;
    background: #020b12;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  #grid-canvas {
    display: block;
    image-rendering: pixelated;
  }

  /* ── Scanline overlay ── */
  .canvas-area::after {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0,0,0,.04) 0px,
      rgba(0,0,0,.04) 1px,
      transparent 1px,
      transparent 3px
    );
    pointer-events: none;
  }

  /* corner decorations */
  .corner { position: absolute; width: 20px; height: 20px; }
  .corner-tl { top:8px; left:8px;  border-top: 1px solid var(--cyan); border-left: 1px solid var(--cyan); }
  .corner-tr { top:8px; right:8px; border-top: 1px solid var(--cyan); border-right: 1px solid var(--cyan); }
  .corner-bl { bottom:8px; left:8px;  border-bottom: 1px solid var(--cyan); border-left: 1px solid var(--cyan); }
  .corner-br { bottom:8px; right:8px; border-bottom: 1px solid var(--cyan); border-right: 1px solid var(--cyan); }

  /* ── Controls (bottom of canvas area) ── */
  .controls {
    position: absolute;
    bottom: 16px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 8px; align-items: center;
    background: rgba(5,13,20,.8);
    border: 1px solid var(--border);
    padding: 8px 16px;
    border-radius: 4px;
    backdrop-filter: blur(4px);
  }
  .btn {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 3px;
    cursor: pointer;
    border: 1px solid;
    transition: all .2s;
  }
  .btn-primary {
    background: rgba(0,212,255,.12);
    border-color: var(--cyan);
    color: var(--cyan);
  }
  .btn-primary:hover {
    background: rgba(0,212,255,.25);
    box-shadow: 0 0 10px rgba(0,212,255,.3);
  }
  .btn-amber {
    background: rgba(245,166,35,.1);
    border-color: var(--amber);
    color: var(--amber);
  }
  .btn-amber:hover { background: rgba(245,166,35,.2); }
  .btn-red {
    background: rgba(255,58,58,.1);
    border-color: var(--red);
    color: var(--red);
  }
  .btn-red:hover { background: rgba(255,58,58,.2); }
  .speed-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--dim);
    margin-left: 4px;
  }
  #speed-display {
    font-family: var(--display);
    font-size: 12px;
    color: var(--amber);
    min-width: 30px;
    text-align: center;
  }

  /* ── Right panel: metrics ── */
  .metrics-panel {
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
  }
  .metric-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
  }
  .metric-label {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--dim);
    text-transform: uppercase;
    letter-spacing: .5px;
  }
  .metric-val {
    font-family: var(--display);
    font-size: 16px;
    font-weight: 700;
  }
  .mv-amber { color: var(--amber); }
  .mv-cyan  { color: var(--cyan);  }
  .mv-green { color: var(--green); }
  .mv-red   { color: var(--red);   }

  /* mini bar */
  .mini-bar-wrap { margin-top: 3px; margin-bottom: 10px; }
  .mini-bar-bg {
    height: 4px; background: var(--border);
    border-radius: 2px; overflow: hidden;
  }
  .mini-bar-fill {
    height: 100%; border-radius: 2px;
    transition: width .4s ease;
  }

  /* log */
  .event-log {
    flex: 1; overflow-y: auto; padding: 6px 12px;
  }
  .event-log::-webkit-scrollbar { width: 3px; }
  .event-log::-webkit-scrollbar-thumb { background: var(--border); }
  .log-entry {
    font-family: var(--mono);
    font-size: 9px;
    padding: 3px 0;
    border-bottom: 1px solid rgba(14,34,51,.4);
    line-height: 1.4;
    color: var(--dim);
  }
  .log-entry.warn  { color: var(--amber); }
  .log-entry.alert { color: var(--red); }
  .log-entry.good  { color: var(--green); }
  .log-entry.info  { color: var(--cyan); }

  /* legend */
  .legend {
    padding: 10px 12px;
    border-top: 1px solid var(--border);
  }
  .legend-row {
    display: flex; align-items: center; gap: 6px;
    margin-bottom: 5px;
    font-family: var(--mono); font-size: 9px; color: var(--dim);
  }
  .legend-dot {
    width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0;
  }
</style>
</head>
<body>

<!-- ── Header ── -->
<header>
  <div class="logo">
