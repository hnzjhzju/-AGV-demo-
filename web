      <div class="legend-row"><div class="legend-dot" style="background:#9b59ff"></div> AGV 送货中</div>
      <div class="legend-row"><div class="legend-dot" style="background:#39ff14"></div> AGV 空闲/充电</div>
      <div class="legend-row"><div class="legend-dot" style="background:#ff3a3a"></div> AGV 阻塞</div>
      <div class="legend-row"><div class="legend-dot" style="background:#334455;border:1px solid #0e2233"></div> 集装箱堆场</div>
      <div class="legend-row"><div class="legend-dot" style="background:#00d4ff;border-radius:50%"></div> 装卸区</div>
